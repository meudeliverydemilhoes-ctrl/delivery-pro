{
  "name": "Modulo",
  "type": "object",
  "properties": {
    "curso_id": {
      "type": "string"
    },
    "nome": {
      "type": "string"
    },
    "descricao": {
      "type": "string"
    },
    "ordem": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "curso_id",
    "nome"
  ],
  "rls": {
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}